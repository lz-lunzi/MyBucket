    "uninstaller": {
        "script": [
            "if (!(is_admin)) { error \"$app requires admin rights to uninstall\"; break }",
            "$msi = Get-ChildItem \"$dir\\Setup.RemoteDesktopManager.win-*.msi\" | Select-Object -First 1",
            "if ($msi) {",
            "    Start-Process -Wait msiexec \"/x `\"$($msi.FullName)`\" /qn /norestart\"",
            "}"
        ]
    },
