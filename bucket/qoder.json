{
    "version": "0.1.31",
    "description": "Qoder CLI - AI-powered coding assistant",
    "homepage": "https://qoder.com",
    "license": "MIT",
    "depends": "nodejs-lts",
    "url": "https://registry.npmjs.org/@qoder-ai/qodercli/-/qodercli-0.1.31.tgz",
    "installer": {
        "script": "npm install --global --prefix $dir $dir\\qodercli-$version.tgz"
    },
    "uninstaller": {
        "script": "npm uninstall --global --prefix $dir @qoder-ai/qodercli"
    },
    "checkver": {
        "url": "https://registry.npmjs.org/@qoder-ai/qodercli/latest",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "url": "https://registry.npmjs.org/@qoder-ai/qodercli/-/qodercli-$version.tgz",
        "hash": {
            "mode": "download"
        }
    }
}
