    },
    "uninstaller": {
        "script": [
            "if (!(is_admin)) { error \"$app requires admin rights to $cmd\"; break }",
            "Stop-Process -Name 'ProcessLasso' -Force -ErrorAction Ignore",
            "Stop-Process -Name 'ProcessGovernor' -Force -ErrorAction Ignore",
            "Stop-Process -Name 'bitsumsessionagent' -Force -ErrorAction Ignore",
            "Start-Process -Wait \"$dir\\uninstall.exe\" -ArgumentList '/S'"
        ]
    },
    "bin": [
        "ProcessLasso.exe"
    ],
    "shortcuts": [
        ["ProcessLasso.exe", "Process Lasso"]
    ],
    "checkver": {
        "url": "https://bitsum.com/processlasso/",
        "regex": "v([\\d.]+)"
