    "pre_install": [
        "if (!(is_admin)) { error \"$app requires admin rights to $cmd\"; break }"
    ],
    "installer": {
        "script": [
            "Start-Process -Wait \"$dir\\processlassosetup64.exe\" -ArgumentList '/S', \"/D=$dir\""
